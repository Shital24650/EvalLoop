# Never commit a real .env file. This is a template only.

# GPT-5.6, served via OpenRouter (comma-separate multiple keys for
# automatic fallback when one hits a quota/billing limit).
OPENAI_API_KEYS=sk-or-key-1,sk-or-key-2,sk-or-key-3,sk-or-key-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-5.6

# Gemini (also supports comma-separated keys for fallback)
GEMINI_API_KEYS=your-gemini-key-1,your-gemini-key-2
GEMINI_MODEL=gemini-2.5-flash

# CORS / server
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173
PORT=4000
OPENAI_TIMEOUT_MS=120000
